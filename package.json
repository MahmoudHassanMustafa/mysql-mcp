{
  "name": "querybridge-mcp",
  "version": "0.1.0",
  "description": "MCP server connecting Claude Code with MySQL — supports SSH tunnels and multiple databases",
  "license": "MIT",
  "author": "Mahmoud Hassan",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/MahmoudHassanMustafa/querybridge-mcp.git"
  },
  "bugs": {
    "url": "https://github.com/MahmoudHassanMustafa/querybridge-mcp/issues"
  },
  "homepage": "https://github.com/MahmoudHassanMustafa/querybridge-mcp#readme",
  "keywords": [
    "mcp",
    "mysql",
    "claude",
    "claude-code",
    "model-context-protocol",
    "ssh-tunnel",
    "database"
  ],
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "bin": {
    "querybridge-mcp": "dist/cli.js",
    "querybridge-mcp-server": "dist/index.js"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "exports": {
    ".": "./dist/index.js"
  },
  "engines": {
    "node": ">=18"
  },
  "scripts": {
    "build": "tsc",
    "start": "node dist/index.js",
    "cli": "node dist/cli.js",
    "dev": "tsc --watch",
    "test": "vitest run",
    "test:watch": "vitest",
    "prepublishOnly": "pnpm build && pnpm test"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.12.1",
    "mysql2": "^3.14.1",
    "ssh2": "^1.16.0",
    "zod": "^3.25.1"
  },
  "devDependencies": {
    "@types/node": "^22.15.3",
    "@types/ssh2": "^1.15.4",
    "typescript": "^5.8.3",
    "vitest": "^4.1.4"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "cpu-features",
      "ssh2"
    ]
  }
}
