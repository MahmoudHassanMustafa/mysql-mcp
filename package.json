{
  "name": "mysql-mcp",
  "version": "1.0.0",
  "description": "MCP server connecting Claude Code with MySQL — supports SSH tunnels and multiple databases",
  "type": "module",
  "main": "dist/index.js",
  "bin": {
    "mysql-mcp": "dist/cli.js",
    "mysql-mcp-server": "dist/index.js"
  },
  "scripts": {
    "build": "tsc",
    "start": "node dist/index.js",
    "cli": "node dist/cli.js",
    "dev": "tsc --watch"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.12.1",
    "mysql2": "^3.14.1",
    "ssh2": "^1.16.0",
    "zod": "^3.25.1"
  },
  "devDependencies": {
    "@types/node": "^22.15.3",
    "@types/ssh2": "^1.15.4",
    "typescript": "^5.8.3"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "cpu-features",
      "ssh2"
    ]
  }
}
